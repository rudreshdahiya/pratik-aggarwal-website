# Formspree form endpoints
# Create forms at https://formspree.io, then paste each form's endpoint URL below.
# Copy this file to .env.local and fill in the real values before deploying.

VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/YOUR_CONTACT_FORM_ID
VITE_STORY_FORM_ENDPOINT=https://formspree.io/f/YOUR_STORY_FORM_ID
